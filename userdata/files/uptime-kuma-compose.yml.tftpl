services:
  uptime-kuma:
    image: louislam/uptime-kuma:1
    container_name: uptime-kuma
    volumes:
      - /opt/server/data/uptime-kuma:/app/data
    restart: unless-stopped
    networks:
      - traefik_net
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=traefik_net"
      - "traefik.http.routers.uptime-kuma.rule=Host(`status.${base_domain}`)"
      - "traefik.http.services.uptime-kuma.loadbalancer.server.port=3001"
networks:
  traefik_net:
    external: true
